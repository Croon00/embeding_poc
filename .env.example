# COS source location produced by crawler_POC
COS_APIKEY=replace_with_cos_service_credential_apikey
COS_RESOURCE_INSTANCE_ID=replace_with_cos_resource_instance_id
COS_BUCKET=replace_with_real_bucket_name
COS_ENDPOINTS_URL=https://s3.us-south.cloud-object-storage.appdomain.cloud
SOURCE_COS_PREFIX=crawler_poc

# watsonx.ai embeddings
WATSONX_APIKEY=replace_later
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=replace_later
WATSONX_VERSION=2023-10-25
WATSONX_EMBEDDING_MODEL_ID=granite-embedding-278m-multilingual
WATSONX_EMBED_BATCH_SIZE=16

# Milvus
MILVUS_URI=https://replace_with_milvus_https_host:31435
MILVUS_HOST=
MILVUS_PORT=
MILVUS_SECURE=false
MILVUS_USERNAME=ibmlhapikey_replace_with_account_email
MILVUS_PASSWORD=replace_with_ibm_cloud_apikey
MILVUS_TOKEN=
MILVUS_DB_NAME=
MILVUS_CA_PEM_PATH=
MILVUS_CA_CERT=
MILVUS_SERVER_PEM_PATH=
MILVUS_SERVER_NAME=
MILVUS_COLLECTION_NAME=policy_embed_index_job_chunks
MILVUS_CONSISTENCY_LEVEL=Bounded
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=AUTOINDEX

# Job behavior
LOCAL_WORKDIR=/tmp/policy-embed-index-job
CHUNK_SIZE=700
CHUNK_OVERLAP=100
EMBED_ONLY_ATTACHMENTS=false
DELETE_EXISTING_IDS=true
